{
  "version": 2,
  "rewrites": [
    { "source": "/proxy", "destination": "/api/proxy" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Range, Accept, Accept-Encoding" },
        { "key": "Access-Control-Expose-Headers", "value": "Content-Length, Content-Range, Content-Type, Accept-Ranges" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
